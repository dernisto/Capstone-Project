# Server
PORT=3000
FRONTEND_URL=http://localhost:3000

# MongoDB (required for login/register)
# Local: install MongoDB and use default below, or set MONGODB_URI
# Atlas: create free cluster at https://cloud.mongodb.com and paste your connection string
MONGODB_URI=mongodb://localhost:27017/quizpulse

# JWT for auth (use a long random string in production)
JWT_SECRET=your-secret-key-change-in-production
# How long tokens stay valid: 7d, 24h, 60m, 3600s (default: 7d)
JWT_EXPIRY=7d

## Analytics uses the existing MySQL/Drizzle database tables (quizResults, users, quizzes, etc.)

# --- AI (required for AI Quiz Generator: topic + PDF → questions) ---
# Easiest: OpenAI — create a key at https://platform.openai.com/api-keys
# Paste your key from https://platform.openai.com/api-keys — never commit real keys
OPENAI_API_KEY=sk-your-openai-key-here
# Optional; default is https://api.openai.com when only OPENAI_API_KEY is set
# OPENAI_BASE_URL=https://api.openai.com
#
# Alternative: any OpenAI-compatible API (e.g. hosted Forge / other providers)
# BUILT_IN_FORGE_API_URL=https://your-provider.example.com
# BUILT_IN_FORGE_API_KEY=your-key
